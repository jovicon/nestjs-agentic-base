# === Server ===
PORT=8080
NODE_ENV=production

# === JWT Auth ===
JWT_SECRET=your-jwt-secret
JWT_ISSUER=vra-bff
JWT_AUDIENCE=ventaagent-ms

# === MongoDB Atlas ===
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net
MONGODB_DATABASE=vra20
MONGODB_VECTOR_DATABASE=vra_vectors

# === Vector Search ===
VECTOR_INDEX_NAME=vector_index
VECTOR_EMBEDDING_DIMENSION=1024

# === Anthropic / LLM ===
ANTHROPIC_API_KEY=sk-ant-...
AGENT_MODEL=anthropic/claude-sonnet-4-20250514

# === Embedding Model ===
EMBEDDING_MODEL=anthropic/voyage-3

# === Google Cloud Storage ===
GCS_BUCKET_NAME=vra-docs-bucket
GCS_PROJECT_ID=your-gcp-project

# === MCP Server ===
MCP_SERVER_PORT=3001

# === Rate Limiting ===
THROTTLE_TTL=60000
THROTTLE_LIMIT=20
